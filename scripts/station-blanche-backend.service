[Unit]
Description=Station Blanche Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/station-blanche/backend
ExecStart=/usr/bin/node /opt/station-blanche/backend/server.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
