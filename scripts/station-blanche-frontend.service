[Unit]
Description=Station Blanche Frontend Service
After=network.target station-blanche-backend.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/station-blanche/frontend
ExecStart=/usr/bin/npx serve -s build -l 3000
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
