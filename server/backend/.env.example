# Serveur
NODE_ENV=production
PORT=3100
HOST=0.0.0.0

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stationblanche_server
DB_USER=stationblanche_server
DB_PASSWORD=CHANGEME

# Redis
REDIS_URL=redis://localhost:6379

# Sécurité
JWT_SECRET=GENERATE_RANDOM_STRING_HERE
SESSION_SECRET=GENERATE_RANDOM_STRING_HERE
API_KEY_SALT=GENERATE_RANDOM_STRING_HERE

# Admin par défaut
ADMIN_USERNAME=admin
ADMIN_PASSWORD=StationBlanche-Admin-2024

# Active Directory (optionnel)
AD_ENABLED=false
AD_DOMAIN=ENTREPRISE.LOCAL
AD_LDAP_URL=ldap://dc.entreprise.local:389
AD_BIND_DN=CN=ServiceAccount,OU=Service,DC=entreprise,DC=local
AD_BIND_PASSWORD=CHANGEME
AD_USER_BASE_DN=OU=Users,DC=entreprise,DC=local
AD_GROUP_BASE_DN=OU=Groups,DC=entreprise,DC=local

# Email (alertes)
SMTP_ENABLED=false
SMTP_HOST=smtp.entreprise.local
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@entreprise.local
SMTP_PASSWORD=CHANGEME
SMTP_FROM=Station Blanche <alerts@entreprise.local>

# Alertes
ALERT_EMAIL_RECIPIENTS=admin@entreprise.local,security@entreprise.local
ALERT_CRITICAL_THRESHOLD=5
ALERT_HIGH_THRESHOLD=10

# Mises à jour ClamAV
CLAMAV_UPDATE_MIRROR=http://database.clamav.net
CLAMAV_UPDATE_INTERVAL=86400000

# Logs
LOG_LEVEL=info
LOG_FILE=/var/log/station-blanche-server/server.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# WebSocket
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=5000

# Rétention des données
LOG_RETENTION_DAYS=90
SCAN_RETENTION_DAYS=180
CERTIFICATE_RETENTION_DAYS=365
